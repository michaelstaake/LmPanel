FROM nvidia/cuda:12.9.2-cudnn-devel-ubuntu24.04

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    ca-certificates \
    cmake \
    curl \
    git \
    libcurl4-openssl-dev \
    python3 \
    python3-pip \
    python3-venv \
    && rm -rf /var/lib/apt/lists/* \
    && ln -sf /usr/bin/python3 /usr/bin/python

COPY requirements.txt ./
RUN python3 -m venv /opt/venv \
    && /opt/venv/bin/pip install --no-cache-dir -r requirements.txt

ENV PATH=/opt/venv/bin:$PATH

ARG LLAMA_CPP_TAG=""
RUN ln -sf /usr/local/cuda/lib64/stubs/libcuda.so /usr/local/cuda/lib64/stubs/libcuda.so.1 \
    && if [ -n "$LLAMA_CPP_TAG" ]; then \
        git clone --depth 1 --branch "$LLAMA_CPP_TAG" https://github.com/ggml-org/llama.cpp.git /opt/llama.cpp; \
    else \
        git clone --depth 1 https://github.com/ggml-org/llama.cpp.git /opt/llama.cpp; \
    fi \
    && LIBRARY_PATH=/usr/local/cuda/lib64/stubs LD_LIBRARY_PATH=/usr/local/cuda/lib64/stubs cmake -S /opt/llama.cpp -B /opt/llama.cpp/build \
        -DLLAMA_BUILD_SERVER=ON \
        -DGGML_CUDA=ON \
        -DCMAKE_LIBRARY_PATH="/usr/local/cuda/lib64/stubs" \
        -DCMAKE_EXE_LINKER_FLAGS="-L/usr/local/cuda/lib64/stubs" \
        -DCMAKE_SHARED_LINKER_FLAGS="-L/usr/local/cuda/lib64/stubs" \
    && LIBRARY_PATH=/usr/local/cuda/lib64/stubs LD_LIBRARY_PATH=/usr/local/cuda/lib64/stubs cmake --build /opt/llama.cpp/build --config Release --target llama-server -j2

COPY app ./app

RUN mkdir -p /app/models /app/logs

ENV LLAMA_SERVER_PATH=/opt/llama.cpp/build/bin/llama-server
ENV SUPPORTED_DEVICES=cpu,nvidia

EXPOSE 8100

CMD ["uvicorn", "app.inference_service:app", "--host", "0.0.0.0", "--port", "8100"]