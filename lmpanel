#!/usr/bin/env bash
set -uo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if [[ "${LMPANEL_DEBUG:-}" == "1" ]]; then
  set -x
fi

if ! bash "$ROOT/scripts/configure-gpu-compose.sh" --quiet; then
  rc=$?
  echo "lmpanel: GPU configure failed (exit $rc). See warnings above." >&2
  exit "$rc"
fi

exec docker compose "$@"
