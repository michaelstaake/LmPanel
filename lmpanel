#!/usr/bin/env bash
set -uo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if [[ "${LMPANEL_DEBUG:-}" == "1" ]]; then
  set -x
fi

if [[ ! -f "$ROOT/.env" && -f "$ROOT/.env.example" ]]; then
  cp "$ROOT/.env.example" "$ROOT/.env"
  echo "lmpanel: created .env from .env.example (edit as needed)." >&2
fi

bash "$ROOT/scripts/configure-gpu-compose.sh" --quiet
rc=$?
if [[ "$rc" -ne 0 ]]; then
  echo "lmpanel: GPU configure failed (exit $rc). See warnings above." >&2
  exit "$rc"
fi

if [[ "${1:-}" == "up" ]]; then
  shift
  detached=true
  compose_args=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -nd)
        detached=false
        shift
        ;;
      -d)
        detached=true
        shift
        ;;
      *)
        compose_args+=("$1")
        shift
        ;;
    esac
  done
  if [[ "$detached" == true ]]; then
    exec docker compose up -d "${compose_args[@]}"
  else
    exec docker compose up "${compose_args[@]}"
  fi
fi

exec docker compose "$@"
