APP_NAME=LmPanel
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8444
APP_LOG_LEVEL=INFO

DATABASE_URL=sqlite:///./data/lmpanel.db

JWT_SECRET=change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
OPENAI_API_AUTH_REQUIRED=true
OPENAI_MODELS_AUTH_REQUIRED=false

MODELS_DIR=./models
DATA_DIR=./data
LOGS_DIR=./logs

LLAMA_SERVER_PATH=/opt/llama.cpp/build/bin/llama-server
LLAMA_HOST=127.0.0.1
LLAMA_BASE_PORT=9100
LLAMA_HEALTH_TIMEOUT_SECONDS=30
LLAMA_STARTUP_TIMEOUT_SECONDS=600
LLAMA_REQUEST_TIMEOUT_SECONDS=300
INFERENCE_SERVICE_URL=http://localhost:8100
INFERENCE_RUNTIME_URLS=
INFERENCE_SERVICE_TIMEOUT_SECONDS=600

# Increase these if Docker marks backend or inference services unhealthy before
# large models finish loading during startup.
STARTUP_HEALTHCHECK_INTERVAL=15s
STARTUP_HEALTHCHECK_TIMEOUT=5s
STARTUP_HEALTHCHECK_RETRIES=40
STARTUP_HEALTHCHECK_START_PERIOD=300s

DEFAULT_CONTEXT_LENGTH=32768
DEFAULT_THREADS=8
DEFAULT_GPU_LAYERS=99

# Pins llama.cpp to a specific release tag across all inference images.
LLAMA_CPP_TAG=b9470

# ROCm inference image build args (docker compose --profile rocm build):
# ROCM_DEV_IMAGE=rocm/dev-ubuntu-24.04:7.2.3-complete
AMDGPU_TARGETS=gfx1200;gfx1201
# Semicolon-separated HIP arch list for the ROCm image build. Default covers RDNA4 (gfx1200/gfx1201).
# Override for other AMD GPUs, e.g. gfx1100 for RX 7900 or gfx1030 for older RDNA2.
# GGML_HIP_RCCL=OFF
# LLAMA_FIT_TO_VRAM=false keeps llama-server from silently dropping GPU layers to fit context.
# ROCM_HSA_OVERRIDE_GFX_VERSION=12.0.1 helps HIP detect RDNA4 (gfx1201) GPUs in the ROCm container.
# ROCM_POOL_PARALLEL=1 avoids multi-slot KV reuse issues on some ROCm multi-GPU stacks.
# ROCM_POOL_CACHE_RAM_MB=0 disables llama-server prompt cache for ROCm pools.
# ROCM_POOL_FLASH_ATTN_ENABLED=false keeps flash-attn disabled for ROCm pools (stability first).
# ROCM_POOL_ALLOW_TENSOR_SPLIT=false keeps ROCm pools on split-mode=layer unless explicitly enabled.

QUEUE_MAX_SIZE=1000
QUEUE_POLL_INTERVAL_MS=100

# Docker web UI (https://localhost:8443). For Vite dev on port 5173 use http://localhost:5173.
FRONTEND_ORIGIN=https://localhost:8443
SSL_CERTFILE=./certs/server.crt
SSL_KEYFILE=./certs/server.key

# Let's Encrypt via Cloudflare DNS-01 (optional; can also configure in Settings → SSL)
# LETSENCRYPT_EMAIL=admin@example.com
# CLOUDFLARE_API_TOKEN=
# LETSENCRYPT_USE_STAGING=false
# DOCKER_FRONTEND_CONTAINER=lmpanel-frontend
# DOCKER_BACKEND_CONTAINER=lmpanel-backend
SUPPORTED_DEVICES=
