# ============================================================
# LmPanel Environment Configuration
# ============================================================
# Copy to .env and adjust values as needed.
# Docker-specific variables are used by docker-compose.yml.
# App variables are read by the Python backend (app/core/config.py).
# ============================================================

# -- Application -----------------------------------------------
APP_NAME=LmPanel
APP_ENV=development
APP_HOST=0.0.0.0
APP_LOG_LEVEL=INFO

# APP_PORT=8444          # Internal listen port (bare-metal only; Docker hardcodes 8000)
# APP_EXTERNAL_PORT=8444 # External-facing port for URLs/CORS (auto-set from BACKEND_PORT in Docker)

# -- Database --------------------------------------------------
DATABASE_URL=sqlite:///./data/lmpanel.db

# -- Authentication --------------------------------------------
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
OPENAI_API_AUTH_REQUIRED=true
OPENAI_MODELS_AUTH_REQUIRED=false

# -- Directories -----------------------------------------------
MODELS_DIR=./models
DATA_DIR=./data
LOGS_DIR=./logs

# -- Docker Host Ports -----------------------------------------
# Host port mappings in docker-compose.yml. Container internals are
# fixed (backend:8000, frontend:443, inference:8100).
FRONTEND_PORT=8443
BACKEND_PORT=8444

# -- Frontend Origin -------------------------------------------
# Auto-computed in Docker from FRONTEND_PORT. Override for custom domains.
FRONTEND_ORIGIN=https://localhost:8443

# For local Vite dev (npm run dev in frontend/), create frontend/.env with:
#   VITE_API_BASE_URL=https://localhost:8444
# In Docker the frontend is served by nginx and uses same-origin /api.

# -- SSL -------------------------------------------------------
SSL_CERTFILE=./certs/server.crt
SSL_KEYFILE=./certs/server.key

# -- Let's Encrypt (optional) ----------------------------------
# Configure via Settings -> SSL, or set here for headless setup.
LETSENCRYPT_EMAIL=
LETSENCRYPT_USE_STAGING=false
LETSENCRYPT_CONFIG_DIR=
CLOUDFLARE_API_TOKEN=

# -- Inference Service -----------------------------------------
# In Docker these are overridden to internal container URLs.
INFERENCE_SERVICE_URL=http://localhost:8100
INFERENCE_RUNTIME_URLS=
INFERENCE_SERVICE_TIMEOUT_SECONDS=600

# -- Llama Server ----------------------------------------------
LLAMA_SERVER_PATH=/opt/llama.cpp/build/bin/llama-server
LLAMA_HOST=127.0.0.1
LLAMA_BASE_PORT=9100
LLAMA_HEALTH_TIMEOUT_SECONDS=30
LLAMA_STARTUP_TIMEOUT_SECONDS=600
LLAMA_REQUEST_TIMEOUT_SECONDS=300
LLAMA_STREAM_STALL_TIMEOUT_SECONDS=120

# When false, llama-server will NOT silently drop GPU layers to fit context.
# Recommended for integrated AMD iGPUs (Vulkan).
LLAMA_FIT_TO_VRAM=false

# Optional: pin llama.cpp to a specific release tag for the inference image.
# Leave unset (default) to build from the latest llama.cpp master branch.
# LLAMA_CPP_TAG=b5592

# -- Default Model Parameters ----------------------------------
DEFAULT_CONTEXT_LENGTH=32768
DEFAULT_THREADS=8
DEFAULT_GPU_LAYERS=99
DEFAULT_TEMPERATURE=0.7
DEFAULT_TOP_P=0.95
DEFAULT_MIN_P=0.05
DEFAULT_TOP_K=40
DEFAULT_PRESENCE_PENALTY=0.0
DEFAULT_REPETITION_PENALTY=1.0

# -- Upload Limits ---------------------------------------------
MAX_UPLOAD_SIZE_MB=102400

# -- Startup Healthchecks --------------------------------------
# Increase retries/start_period if Docker marks services unhealthy before
# large models finish loading during startup.
STARTUP_HEALTHCHECK_INTERVAL=15s
STARTUP_HEALTHCHECK_TIMEOUT=5s
STARTUP_HEALTHCHECK_RETRIES=40
STARTUP_HEALTHCHECK_START_PERIOD=300s

# -- Queue -----------------------------------------------------
QUEUE_MAX_SIZE=1000
QUEUE_POLL_INTERVAL_MS=100

# -- GPU Recovery Watchdog -------------------------------------
# Periodically re-syncs returning GPUs and auto-restarts crashed models.
DEVICE_WATCHDOG_ENABLED=true
DEVICE_WATCHDOG_INTERVAL_SECONDS=30
GPU_READY_TIMEOUT_SECONDS=120
GPU_READY_GRACE_SECONDS=20
MODEL_RECOVERY_MAX_ATTEMPTS=5

# -- Model Activation Safety -----------------------------------
# Prevents host RAM exhaustion from concurrent Vulkan loads.
MODEL_ACTIVATION_MIN_FREE_RAM_MB=4096
MODEL_ACTIVATION_RAM_HEADROOM_RATIO=1.25
MODEL_ACTIVATION_GPU_OFFLOAD_HEADROOM_RATIO=0.20
MODEL_ACTIVATION_GPU_NO_MMAP_HEADROOM_RATIO=0.50
WATCHDOG_MAX_ACTIVATIONS_PER_TICK=1

# Auto-load previously active models on startup (default: manual activation).
AUTO_LOAD_ACTIVATED_MODELS_ON_STARTUP=false

# -- VRAM Preflight --------------------------------------------
# Integrated AMD iGPUs: LmPanel reports VRAM+GTT from amdgpu sysfs.
# GTT size is set via amdgpu.gttsize kernel param (often ~50% of RAM).
# Lower DEFAULT_CONTEXT_LENGTH if models OOM despite passing the size check.
VULKAN_FLASH_ATTENTION_DEFAULT=auto
VRAM_KV_MB_PER_1K_TOKENS=80
VRAM_COMPUTE_MARGIN_MB=512
VRAM_HEADROOM_MB=1024
MODEL_ACTIVATION_MAX_GTT_USED_RATIO=0.85
GPU_RESET_COOLDOWN_TICKS=2

# -- Multi-GPU Pool (Vulkan) -----------------------------------
POOL_DEFAULT_BATCH_SIZE=4096
POOL_DEFAULT_UBATCH_SIZE=512
POOL_STARTUP_TIMEOUT_SECONDS=300
POOL_PREFER_SINGLE_GPU_WHEN_FIT=true
POOL_TENSOR_SPLIT_FALLBACK=true

# -- Inference Container Memory --------------------------------
# Adjust for your host RAM. Example: 64 GB host, leaving room for OS + backend.
INFERENCE_MEM_LIMIT=52g
INFERENCE_MEMSWAP_LIMIT=52g

# -- Docker Container Names ------------------------------------
# Only needed if you customize the container names in docker-compose.yml.
DOCKER_FRONTEND_CONTAINER=lmpanel-frontend
DOCKER_BACKEND_CONTAINER=lmpanel-backend

# -- Supported Devices -----------------------------------------
# Comma-separated list of devices (e.g. "cpu,vulkan"). Leave empty for auto-detect.
SUPPORTED_DEVICES=
