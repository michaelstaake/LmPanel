# Use the -complete image so hipBLAS/rocBLAS CMake packages are available during llama.cpp build.
ARG ROCM_DEV_IMAGE=rocm/dev-ubuntu-24.04:7.2.3-complete
FROM ${ROCM_DEV_IMAGE}

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    ca-certificates \
    cmake \
    curl \
    git \
    libcurl4-openssl-dev \
    python3 \
    python3-pip \
    python3-venv \
    rocm-smi-lib \
    && rm -rf /var/lib/apt/lists/* \
    && ln -sf /usr/bin/python3 /usr/bin/python \
    && groupadd -f -g 44 video \
    && groupadd -f -g 104 render

COPY requirements.txt ./
RUN python3 -m venv /opt/venv \
    && /opt/venv/bin/pip install --no-cache-dir -r requirements.txt

ENV PATH=/opt/venv/bin:/opt/rocm/bin:/opt/rocm/llvm/bin:$PATH
ENV ROCM_PATH=/opt/rocm

ARG LLAMA_CPP_TAG="b9297"
# Docker builds cannot auto-detect GPU arch; override AMDGPU_TARGETS in .env for other AMD GPUs.
ARG AMDGPU_TARGETS="gfx1200;gfx1201"
ARG GGML_HIP_RCCL="OFF"

RUN git clone --depth 1 --branch "${LLAMA_CPP_TAG}" https://github.com/ggml-org/llama.cpp.git /opt/llama.cpp \
    && HIPCXX="$(hipconfig -l)/clang" HIP_PATH="$(hipconfig -R)" \
    cmake -S /opt/llama.cpp -B /opt/llama.cpp/build \
        -DLLAMA_BUILD_SERVER=ON \
        -DGGML_HIP=ON \
        -DGGML_HIP_RCCL=${GGML_HIP_RCCL} \
        -DAMDGPU_TARGETS="${AMDGPU_TARGETS}" \
        -DCMAKE_C_COMPILER=/opt/rocm/llvm/bin/clang \
        -DCMAKE_CXX_COMPILER=/opt/rocm/llvm/bin/clang++ \
        -DCMAKE_BUILD_TYPE=Release \
    && cmake --build /opt/llama.cpp/build --config Release --target llama-server -j2

COPY app ./app

RUN mkdir -p /app/models /app/logs

ENV LLAMA_SERVER_PATH=/opt/llama.cpp/build/bin/llama-server
ENV SUPPORTED_DEVICES=cpu,rocm

EXPOSE 8100

CMD ["uvicorn", "app.inference_service:app", "--host", "0.0.0.0", "--port", "8100"]
